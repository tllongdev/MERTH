# MERTH service configuration. Copy to .env (the service reads the environment).

# Home Depot is fronted by Akamai Bot Manager. Scrapling's StealthyFetcher clears
# most fingerprint/leak detection on its own, but Akamai's sensor scoring may still
# flag a datacenter IP. Point this at a RESIDENTIAL proxy to route every request
# through it. Format: http://user:pass@host:port (or socks5://...).
MERTH_PROXY=

# Run the stealth browser headless (true) or headful (false). Headful sometimes
# clears Akamai more reliably during local debugging.
MERTH_HEADLESS=true

# Per-operation navigation/wait timeout in milliseconds.
MERTH_TIMEOUT_MS=45000

# CORS: the origin of the Next.js web app allowed to call this service.
MERTH_WEB_ORIGIN=http://localhost:3000
